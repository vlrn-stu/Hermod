{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Hermod.LoRa2MQTT.DeviceMocker": "Debug"
    }
  },
  "Mocker": {
    "SerialPort": "/dev/ttyACM1",
    "BaudRate": 115200,
    "Mode": "Normal",
    "Address": 100,
    "DeviceName": "mock-sensor-1",
    "IntervalMs": 1000,
    "BurstCount": 1000,
    "FloodMessagesPerMinute": 600,
    "OversizePayloadBytes": 512,
    "ReplayCount": 10,
    "SpoofAddress": 0,
    "AppendLf": true,
    "RunOnce": false
  }
}
