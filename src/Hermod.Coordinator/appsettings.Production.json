{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hermod": "Information"
    }
  },
  "AllowedHosts": "*",
  "Vault42": {
    "Authority": "http://vault42.hermod.svc.cluster.local:8080"
  },
  "Hermod": {
    "Mqtt": {
      "Host": "nanomq",
      "Port": 1883,
      "ClientId": "hermod-coordinator",
      "KeepAliveSeconds": 60,
      "CleanSession": true,
      "Topics": {
        "Zigbee": "zigbee/#",
        "Lora": "lora/#",
        "Bluetooth": "bluetooth/#",
        "Wifi": "wifi/#",
        "System": "hermod/#"
      }
    },
    "Database": {
      "ConnectionString": "Host=postgres;Port=5432;Database=hermod;Username=hermod_app;Password=hermod-app-password-change-me",
      "DatabaseName": "hermod"
    },
    "ProtocolTranslators": {
      "Zigbee2Mqtt": {
        "Enabled": true,
        "Url": "http://zigbee2mqtt:8080"
      },
      "Ble2Mqtt": {
        "Enabled": true
      },
      "Lora2Mqtt": {
        "Enabled": true,
        "Url": "http://lora2mqtt:8080"
      },
      "Wifi2Mqtt": {
        "Enabled": true,
        "Url": "mqtt://wifi2mqtt.hermod.svc.cluster.local:1883"
      }
    },
    "Features": {
      "DeviceStateTracking": true,
      "MessagePersistence": false,
      "RuleAuditLog": false,
      "StatsRollup": true,
      "RuleCache": true,
      "MetricsEndpoint": false
    },
    "Storage": {
      "Mode": "Postgres",
      "WriteBatchSize": 256,
      "WriteFlushIntervalMs": 500,
      "WriteQueueCapacity": 50000,
      "MaxPoolSize": 50,
      "MinPoolSize": 5,
      "CommandTimeoutSeconds": 30,
      "KeepAliveSeconds": 30,
      "SkipDeviceExistenceCheck": true
    },
    "Engine": {
      "Parallelism": 0,
      "BatchSize": 64,
      "QueueCapacity": 10000,
      "LogBatching": true,
      "LogBatchSize": 100,
      "LogBatchIntervalMs": 1000,
      "RuleCacheRefreshSeconds": 5
    },
    "Seed": {
      "Devices": false,
      "Rules": false
    },
    "Dev": {
      "Endpoints": false
    }
  }
}
