@using Hermod.Coordinator.Components.Pages
@using Microsoft.AspNetCore.Components.Authorization

<Router AppAssembly="@typeof(Program).Assembly">
    <Found Context="routeData">
        @{
            var pageLayout = IsPublicPage(routeData.PageType)
                ? typeof(Layout.AuthLayout)
                : typeof(Layout.MainLayout);
        }
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@pageLayout">
            <NotAuthorized>
                @* Unauthenticated → bounce to /login via Blazor client-side nav.
                   Authenticated but role-gated → show a clear denied panel. *@
                @if (context.User.Identity?.IsAuthenticated != true)
                {
                    <RedirectToLogin />
                }
                else
                {
                    <LayoutView Layout="@typeof(Layout.MainLayout)">
                        <div class="container mt-5">
                            <div class="alert alert-danger">
                                <h4>Access denied</h4>
                                <p>You are signed in but your account does not have permission to view this page.</p>
                                <a href="/" class="btn btn-primary">Back to Home</a>
                            </div>
                        </div>
                    </LayoutView>
                }
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(Layout.MainLayout)">
            <div class="container mt-5">
                <div class="alert alert-warning">
                    <h4>Page Not Found</h4>
                    <p>The page you requested does not exist.</p>
                    <a href="/" class="btn btn-primary">Go Home</a>
                </div>
            </div>
        </LayoutView>
    </NotFound>
</Router>

@code {
    // Pages that render in the auth (centered-card) layout AND are allowed
    // for anonymous users. The actual authorization enforcement happens via
    // AuthorizeRouteView + [AllowAnonymous]/[Authorize] attributes on each
    // page component. This set only controls layout selection.
    private static readonly HashSet<Type> PublicPages = new()
    {
        typeof(Login),
        typeof(Error),
    };

    private static bool IsPublicPage(Type pageType) => PublicPages.Contains(pageType);
}
