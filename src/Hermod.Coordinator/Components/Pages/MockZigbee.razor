                    </button>
                </div>
            </div>
        }
        else if (_activeTab == "custom")
        {
            <!-- Custom Message Builder -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0">
                    <h5 class="mb-0 fw-semibold">Custom Message Builder</h5>
                    <small class="text-muted">Build and send any ZigBee2MQTT message</small>
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">Topic Template</label>
                            <select class="form-select" @onchange="OnTopicTemplateChange">
                                <option value="">-- Select Template --</option>
                                <option value="zigbee/bridge/state">Bridge State</option>
                                <option value="zigbee/bridge/info">Bridge Info</option>
                                <option value="zigbee/bridge/devices">Bridge Devices</option>
                                <option value="zigbee/bridge/groups">Bridge Groups</option>
                                <option value="zigbee/bridge/event">Bridge Event</option>
                                <option value="zigbee/bridge/logging">Bridge Logging</option>
                                <option value="zigbee/[device]">Device State</option>
                                <option value="zigbee/[device]/availability">Device Availability</option>
                                <option value="zigbee/[device]/set">Device Set</option>
                                <option value="zigbee/[device]/get">Device Get</option>
                                <option value="zigbee/bridge/request/permit_join">Request: Permit Join</option>
                                <option value="zigbee/bridge/request/device/rename">Request: Device Rename</option>
                            </select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Topic</label>
                            <input type="text" class="form-control font-monospace" @bind="_customTopic" placeholder="zigbee/..." />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Payload (JSON)</label>
                        <textarea class="form-control font-monospace" rows="8" @bind="_customPayload" placeholder='{"key": "value"}'></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary flex-grow-1" @onclick="SendCustomMessage" disabled="@(!MqttService.IsConnected || string.IsNullOrEmpty(_customTopic))">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1" viewBox="0 0 16 16">
                                <path d="M15.964.686a.5.5 0 0 0-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 0 0-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.002.26.41a.5.5 0 0 0 .886-.083l6-15Z"/>
                            </svg>
                            Send Message
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="FormatPayload">
                            Format JSON
                        </button>
                        <button class="btn btn-outline-danger" @onclick="ClearCustom">
                            Clear
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Right Panel: Message Log -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-semibold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2 text-info" viewBox="0 0 16 16">
                        <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/>
                        <path d="M3 5.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zM3 8a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 8zm0 2.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5z"/>
                    </svg>
                    MQTT Log
                </h5>
                <div class="d-flex gap-2">
                    <select class="form-select form-select-sm" style="width: auto;" @bind="_logFilter">
                        <option value="">All Messages</option>
                        <option value="bridge">Bridge Only</option>
                        <option value="device">Devices Only</option>
                        <option value="request">Requests</option>
                        <option value="response">Responses</option>
                    </select>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearMessages">Clear</button>
                </div>
            </div>
            <div class="card-body p-0">
                <div style="height: 600px; overflow-y: auto;">
                    @if (FilteredMessages.Any())
                    {
                        @foreach (var msg in FilteredMessages.OrderByDescending(m => m.ReceivedAt).Take(100))
                        {
                            <div class="border-bottom p-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <code class="@GetTopicColor(msg.Topic) small">@msg.Topic</code>
                                    <small class="text-muted">@msg.ReceivedAt.ToLocalTime().ToString("HH:mm:ss.fff")</small>
                                </div>
                                <pre class="bg-light rounded p-2 mb-0 small" style="max-height: 150px; overflow: auto; white-space: pre-wrap;">@FormatJson(msg.Payload)</pre>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="mb-3 opacity-50" viewBox="0 0 16 16">
                                <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/>
                                <path d="M10.97 4.97a.75.75 0 0 1 1.071 1.05l-3.992 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425a.235.235 0 0 1 .02-.022z"/>
                            </svg>
                            <p class="mb-1">No messages yet</p>
                            <small>MQTT messages will appear here</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly CancellationTokenSource _pageCts = new();
    private string _activeTab = "bridge";
    private int _messagesSent;
    private bool _bridgeOnline = true;
    private readonly List<MqttMessage> _receivedMessages = new();
    private string _logFilter = "";
    private string? _errorMessage;

    // Bridge settings
    private string _bridgeVersion = "1.40.2";
    private string _coordinatorType = "zStack3x0";
    private int _networkChannel = 11;
    private int _panId = 6754;
    private string _permitJoin = "false";

    // Device state settings
    private int _selectedDeviceIndex = 0;
    private string _lightState = "ON";
    private int _lightBrightness = 200;
    private int _lightColorTemp = 370;
    private double _sensorTemp = 22.5;
    private double _sensorHumidity = 45.0;
    private int _sensorBattery = 85;
    private int _linkQuality = 120;
    private string _motionOccupancy = "false";
    private int _motionIlluminance = 150;
    private string _contactState = "true";
    private string _switchState = "ON";
    private double _plugPower = 45.2;
    private int _plugVoltage = 230;

    // Event settings
    private int _eventDeviceIndex = 0;
    private string _logLevel = "info";
    private string _logMessage = "";

    // Request settings
    private int _requestDeviceIndex = 0;
    private string _newDeviceName = "";
    private string _responseType = "permit_join";
    private string _responseStatus = "ok";

    // Custom message
    private string _customTopic = "";
    private string _customPayload = "";

    // Mock devices
    private readonly List<MockZigbeeDevice> _mockDevices = new();

    private MockZigbeeDevice? SelectedDevice => _selectedDeviceIndex >= 0 && _selectedDeviceIndex < _mockDevices.Count
        ? _mockDevices[_selectedDeviceIndex] : null;

    private MockZigbeeDevice? EventDevice => _eventDeviceIndex >= 0 && _eventDeviceIndex < _mockDevices.Count
        ? _mockDevices[_eventDeviceIndex] : null;

    private MockZigbeeDevice? RequestDevice => _requestDeviceIndex >= 0 && _requestDeviceIndex < _mockDevices.Count
        ? _mockDevices[_requestDeviceIndex] : null;

    private IEnumerable<MqttMessage> FilteredMessages
    {
        get
        {
            // Snapshot under the writer lock so the render-time LINQ filter
            // never enumerates concurrently with HandleMessage appending.
            MqttMessage[] snapshot;
            lock (_receivedMessages)
            {
                snapshot = _receivedMessages.ToArray();
            }

            return _logFilter switch
            {
                "bridge" => snapshot.Where(m => m.Topic.Contains("/bridge/") && !m.Topic.Contains("/request/") && !m.Topic.Contains("/response/")),
                "device" => snapshot.Where(m => m.Topic.StartsWith("zigbee/") && !m.Topic.Contains("/bridge/")),
                "request" => snapshot.Where(m => m.Topic.Contains("/request/")),
                "response" => snapshot.Where(m => m.Topic.Contains("/response/")),
                _ => snapshot
            };
        }
    }

    protected override void OnInitialized()
    {
        InitializeMockDevices();
        MqttService.MessageReceived += HandleMessage;
    }

    private void InitializeMockDevices()
    {
        _mockDevices.AddRange(new[]
        {
            // Lights
            new MockZigbeeDevice("living_room_light", "0x00124b0025a1b2c3", "Router", "light", "IKEA", "TRADFRI bulb E27 WS opal 980lm", "LED1545G12", "Mains (single phase)"),
            new MockZigbeeDevice("kitchen_light", "0x00124b0025a1b2c4", "Router", "light", "Philips", "Hue white ambiance E27", "LWA001", "Mains (single phase)"),
            new MockZigbeeDevice("bedroom_light", "0x00124b0025a1b2c5", "Router", "light", "IKEA", "TRADFRI LED bulb E26/E27 806 lumen", "LED1836G9", "Mains (single phase)"),

            // Sensors
            new MockZigbeeDevice("temp_sensor_bedroom", "0x00158d0004512b34", "EndDevice", "sensor", "Xiaomi", "Aqara temperature, humidity and pressure sensor", "WSDCGQ11LM", "Battery"),
            new MockZigbeeDevice("temp_sensor_living", "0x00158d0004512b35", "EndDevice", "sensor", "Xiaomi", "Aqara temperature, humidity and pressure sensor", "WSDCGQ11LM", "Battery"),
            new MockZigbeeDevice("temp_sensor_server_room", "0x00158d0004512b36", "EndDevice", "sensor", "Sonoff", "SNZB-02 temperature and humidity sensor", "SNZB-02", "Battery"),

            // Motion sensors
            new MockZigbeeDevice("motion_sensor_hall", "0x00158d0004238a12", "EndDevice", "motion", "Xiaomi", "Aqara human body movement and illuminance sensor", "RTCGQ11LM", "Battery"),
            new MockZigbeeDevice("motion_sensor_garage", "0x00158d0004238a13", "EndDevice", "motion", "Philips", "Hue motion sensor", "SML001", "Battery"),

            // Contact sensors
            new MockZigbeeDevice("door_contact_front", "0x00158d0004238b01", "EndDevice", "contact", "Xiaomi", "Aqara door & window contact sensor", "MCCGQ11LM", "Battery"),
            new MockZigbeeDevice("door_contact_back", "0x00158d0004238b02", "EndDevice", "contact", "Sonoff", "SNZB-04 contact sensor", "SNZB-04", "Battery"),
            new MockZigbeeDevice("window_contact_bedroom", "0x00158d0004238b03", "EndDevice", "contact", "Xiaomi", "Aqara door & window contact sensor", "MCCGQ11LM", "Battery"),

            // Plugs/Switches
            new MockZigbeeDevice("smart_plug_office", "0x00158d0004567890", "Router", "plug", "Xiaomi", "Mi power plug ZigBee", "ZNCZ02LM", "Mains (single phase)"),
            new MockZigbeeDevice("smart_plug_kitchen", "0x00158d0004567891", "Router", "plug", "BlitzWolf", "BW-SHP13 Zigbee 3.0 smart plug", "TS0121_plug", "Mains (single phase)"),
            new MockZigbeeDevice("wall_switch_garage", "0x00158d0004567892", "Router", "switch", "Sonoff", "ZBMINI Zigbee smart switch", "ZBMINI", "Mains (single phase)")
        });
    }

    private void HandleMessage(object? sender, MqttMessage message)
    {
        if (message.Topic.StartsWith("zigbee/"))
        {
            lock (_receivedMessages)
            {
                _receivedMessages.Add(message);
                if (_receivedMessages.Count > 500)
                    _receivedMessages.RemoveAt(0);
            }
        }
        InvokeAsync(StateHasChanged);
    }

    // Bridge messages
    private async Task SendBridgeState(bool online)
    {
        _bridgeOnline = online;
        var payload = JsonSerializer.Serialize(new { state = online ? "online" : "offline" });
        await SafePublishAsync("zigbee/bridge/state", payload);
    }

    private async Task SendBridgeInfo()
    {
        var info = new
        {
            version = _bridgeVersion,
            commit = "unknown",
            coordinator = new
            {
                type = _coordinatorType,
                ieee_address = "0x00124b001cd4d319",
                meta = new { revision = 20240315, transportrev = 2, product = 1, majorrel = 2, minorrel = 7, maintrel = 1 }
            },
            network = new { channel = _networkChannel, pan_id = _panId, extended_pan_id = new[] { 0xdd, 0xdd, 0xdd, 0x01, 0x02, 0x03, 0x04, 0x05 } },
            log_level = "info",
            permit_join = bool.Parse(_permitJoin),
            permit_join_end = (object?)null,
            restart_required = false,
            config = new { homeassistant = true, permit_join = bool.Parse(_permitJoin) },
            config_schema = new { },
            zigbee_herdsman_converters = new { version = "15.125.0" },
            zigbee_herdsman = new { version = "0.57.5" }
        };
        await SafePublishAsync("zigbee/bridge/info", JsonSerializer.Serialize(info, new JsonSerializerOptions { WriteIndented = false }));
    }

    private async Task SendDeviceDiscovery()
    {
        var devices = _mockDevices.Select(d => new
        {
            ieee_address = d.IeeeAddress,
            type = d.Type,
            network_address = Random.Shared.Next(1000, 65000),
            supported = true,
            disabled = false,
            friendly_name = d.FriendlyName,
            endpoints = new Dictionary<string, object>
            {
                ["1"] = new { bindings = Array.Empty<object>(), configured_reportings = Array.Empty<object>(), clusters = new { input = new[] { "genOnOff", "genBasic" }, output = Array.Empty<string>() } }
            },
            definition = new { model = d.ModelId, vendor = d.Vendor, description = d.Description, exposes = Array.Empty<object>(), options = Array.Empty<object>() },
            power_source = d.PowerSource,
            model_id = d.ModelId,
            interview_completed = true,
            interviewing = false
        }).ToList();

        await SafePublishAsync("zigbee/bridge/devices", JsonSerializer.Serialize(devices));
    }

    // Device state messages
    private async Task SendDeviceState()
    {
        if (SelectedDevice == null) return;

        var payload = SelectedDevice.DeviceType switch
        {
            "light" => JsonSerializer.Serialize(new { state = _lightState, brightness = _lightBrightness, color_temp = _lightColorTemp, linkquality = _linkQuality }),
            "sensor" => JsonSerializer.Serialize(new { temperature = _sensorTemp, humidity = _sensorHumidity, battery = _sensorBattery, linkquality = _linkQuality, voltage = _sensorBattery * 30 + 100 }),
            "motion" => JsonSerializer.Serialize(new { occupancy = bool.Parse(_motionOccupancy), illuminance = _motionIlluminance, illuminance_lux = _motionIlluminance, battery = _sensorBattery, linkquality = _linkQuality }),
            "contact" => JsonSerializer.Serialize(new { contact = bool.Parse(_contactState), battery = _sensorBattery, linkquality = _linkQuality, voltage = _sensorBattery * 30 + 100 }),
            "plug" or "switch" => JsonSerializer.Serialize(new { state = _switchState, power = _plugPower, voltage = _plugVoltage, current = Math.Round(_plugPower / _plugVoltage, 2), linkquality = _linkQuality }),
            _ => "{}"
        };

        await SafePublishAsync($"zigbee/{SelectedDevice.FriendlyName}", payload);
    }

    private async Task SendDeviceAvailability(bool online)
    {
        if (SelectedDevice == null) return;
        var payload = JsonSerializer.Serialize(new { state = online ? "online" : "offline" });
        await SafePublishAsync($"zigbee/{SelectedDevice.FriendlyName}/availability", payload);
    }

    private async Task SendQuickDeviceState(MockZigbeeDevice device)
    {
        var payload = device.DeviceType switch
        {
            "light" => """{"state":"ON","brightness":200,"color_temp":370,"linkquality":120}""",
            "sensor" => """{"temperature":22.5,"humidity":45,"battery":85,"linkquality":105,"voltage":2950}""",
            "motion" => """{"occupancy":true,"illuminance":150,"illuminance_lux":150,"battery":90,"linkquality":110}""",
            "contact" => """{"contact":true,"battery":78,"linkquality":95,"voltage":2800}""",
            "plug" or "switch" => """{"state":"ON","power":45.2,"voltage":230,"current":0.2,"linkquality":115}""",
            _ => "{}"
        };
        await SafePublishAsync($"zigbee/{device.FriendlyName}", payload);
    }

    private async Task SendAllDeviceStates()
    {
        foreach (var device in _mockDevices)
        {
            await SendQuickDeviceState(device);
            await Task.Delay(50);
        }
    }

    // Event messages
    private async Task SendBridgeEvent(string eventType)
    {
        if (EventDevice == null) return;

        object eventData = eventType switch
        {
            "device_joined" => new { type = "device_joined", data = new { friendly_name = EventDevice.FriendlyName, ieee_address = EventDevice.IeeeAddress } },
            "device_announce" => new { type = "device_announce", data = new { friendly_name = EventDevice.FriendlyName, ieee_address = EventDevice.IeeeAddress } },
            "device_interview_started" => new { type = "device_interview", data = new { friendly_name = EventDevice.FriendlyName, ieee_address = EventDevice.IeeeAddress, status = "started" } },
            "device_interview_successful" => new { type = "device_interview", data = new { friendly_name = EventDevice.FriendlyName, ieee_address = EventDevice.IeeeAddress, status = "successful", supported = true, definition = new { model = EventDevice.ModelId, vendor = EventDevice.Vendor, description = EventDevice.Description } } },
            "device_interview_failed" => new { type = "device_interview", data = new { friendly_name = EventDevice.FriendlyName, ieee_address = EventDevice.IeeeAddress, status = "failed" } },
            "device_leave" => new { type = "device_leave", data = new { friendly_name = EventDevice.FriendlyName, ieee_address = EventDevice.IeeeAddress } },
            _ => new { type = eventType, data = new { friendly_name = EventDevice.FriendlyName, ieee_address = EventDevice.IeeeAddress } }
        };

        await SafePublishAsync("zigbee/bridge/event", JsonSerializer.Serialize(eventData));
    }

    private async Task SendLogMessage()
    {
        var msg = string.IsNullOrEmpty(_logMessage) ? "Test log message from Hermod Mock" : _logMessage;
        var payload = JsonSerializer.Serialize(new { level = _logLevel, message = msg, @namespace = "z2m" });
        await SafePublishAsync("zigbee/bridge/logging", payload);
    }

    // Request messages
    private async Task SendPermitJoin(bool enable)
    {
        var payload = JsonSerializer.Serialize(new { time = enable ? 254 : 0 });
        await SafePublishAsync("zigbee/bridge/request/permit_join", payload);
    }

    private Task SendHealthCheck() =>
        SafePublishAsync("zigbee/bridge/request/health_check", "{}");

    private Task SendDeviceConfigure() =>
        SendDeviceIdRequestAsync("configure");

    private Task SendDeviceInterview() =>
        SendDeviceIdRequestAsync("interview");

    private async Task SendDeviceIdRequestAsync(string action)
    {
        if (RequestDevice is null) return;
        var payload = JsonSerializer.Serialize(new { id = RequestDevice.FriendlyName });
        await SafePublishAsync($"zigbee/bridge/request/device/{action}", payload);
    }

    private async Task SendDeviceRename()
    {
        if (RequestDevice is null || string.IsNullOrEmpty(_newDeviceName)) return;
        var payload = JsonSerializer.Serialize(new { from = RequestDevice.FriendlyName, to = _newDeviceName });
        await SafePublishAsync("zigbee/bridge/request/device/rename", payload);
    }

    private Task SendDeviceRemove() => SendDeviceIdRequestAsync("remove");

    private async Task SendMockResponse()
    {
        object responseData = (_responseType, _responseStatus) switch
        {
            ("permit_join", "ok") => new { data = new { time = 254 }, status = "ok" },
            ("health_check", "ok") => new { data = new { healthy = true }, status = "ok" },
            ("device/configure", "ok") => new { data = new { id = RequestDevice?.FriendlyName ?? "device" }, status = "ok" },
            ("device/rename", "ok") => new { data = new { from = RequestDevice?.FriendlyName ?? "device", to = _newDeviceName, homeassistant_rename = false }, status = "ok" },
            ("device/remove", "ok") => new { data = new { id = RequestDevice?.FriendlyName ?? "device", block = false, force = false }, status = "ok" },
            ("networkmap", "ok") => new { data = new { type = "graphviz", value = "digraph G { }", routes = false }, status = "ok" },
            (_, "error") => new { data = new { }, error = "Mock error message", status = "error" },
            _ => new { data = new { }, status = "ok" }
        };

        await SafePublishAsync($"zigbee/bridge/response/{_responseType}", JsonSerializer.Serialize(responseData));
    }

    private async Task SendCustomMessage()
    {
        if (string.IsNullOrEmpty(_customTopic)) return;
        var payload = string.IsNullOrEmpty(_customPayload) ? "{}" : _customPayload;
        await SafePublishAsync(_customTopic, payload);
    }

    private void OnTopicTemplateChange(ChangeEventArgs e)
    {
        var template = e.Value?.ToString() ?? "";
        if (string.IsNullOrEmpty(template)) return;

        _customTopic = template.Replace("[device]", _mockDevices.FirstOrDefault()?.FriendlyName ?? "device_name");

        _customPayload = template switch
        {
            "zigbee/bridge/state" => """{"state": "online"}""",
            "zigbee/bridge/info" => """{"version": "1.40.2", "coordinator": {"type": "zStack3x0"}, "network": {"channel": 11, "pan_id": 6754}}""",
            "zigbee/bridge/devices" => """[{"ieee_address": "0x00124b0025a1b2c3", "type": "Router", "friendly_name": "living_room_light", "supported": true}]""",
            "zigbee/bridge/groups" => """[{"id": 1, "friendly_name": "living_room_group", "members": []}]""",
            "zigbee/bridge/event" => """{"type": "device_joined", "data": {"friendly_name": "new_device", "ieee_address": "0x00158d0004512b99"}}""",
            "zigbee/bridge/logging" => """{"level": "info", "message": "Test message", "namespace": "z2m"}""",
            var t when t.EndsWith("/availability") => """{"state": "online"}""",
            var t when t.EndsWith("/set") => """{"state": "ON", "brightness": 200}""",
            var t when t.EndsWith("/get") => """{"state": ""}""",
            "zigbee/bridge/request/permit_join" => """{"time": 254}""",
            "zigbee/bridge/request/device/rename" => """{"from": "old_name", "to": "new_name"}""",
            _ when template.Contains("[device]") => """{"state": "ON", "brightness": 200, "linkquality": 120}""",
            _ => "{}"
        };
    }

    private void FormatPayload()
    {
        try
        {
            var obj = JsonSerializer.Deserialize<object>(_customPayload);
            _customPayload = JsonSerializer.Serialize(obj, new JsonSerializerOptions { WriteIndented = true });
        }
        catch { }
    }

    private void ClearCustom()
    {
        _customTopic = "";
        _customPayload = "";
    }

    private void ClearMessages()
    {
        lock (_receivedMessages) { _receivedMessages.Clear(); }
    }

    // Helpers
    private static string GetDeviceTypeBadge(string type) => type switch
    {
        "Coordinator" => "bg-danger",
        "Router" => "bg-success",
        "EndDevice" => "bg-info",
        _ => "bg-secondary"
    };

    private static string GetTopicColor(string topic) => topic switch
    {
        var t when t.Contains("/bridge/state") => "text-success",
        var t when t.Contains("/bridge/info") => "text-info",
        var t when t.Contains("/bridge/event") => "text-warning",
        var t when t.Contains("/bridge/logging") => "text-muted",
        var t when t.Contains("/request/") => "text-primary",
        var t when t.Contains("/response/") => "text-success",
        var t when t.Contains("/availability") => "text-warning",
        var t when t.Contains("/set") => "text-danger",
        _ => "text-primary"
    };

    private static string FormatJson(string payload)
    {
        try
        {
            var obj = JsonSerializer.Deserialize<object>(payload);
            return JsonSerializer.Serialize(obj, new JsonSerializerOptions { WriteIndented = true });
        }
        catch { return payload; }
    }

    private async Task SafePublishAsync(string topic, string payload)
    {
        try
        {
            var mqtt = MqttService;
            await mqtt.PublishAsync(topic, payload, cancellationToken: _pageCts.Token);
            _messagesSent++;
            _errorMessage = null;
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to publish Zigbee2MQTT mock message to {Topic}", topic);
            _errorMessage = $"Failed to publish to {topic}. See coordinator logs.";
        }
    }

    public void Dispose()
    {
        MqttService.MessageReceived -= HandleMessage;
        _pageCts.Cancel();
        _pageCts.Dispose();
    }

    private record MockZigbeeDevice(string FriendlyName, string IeeeAddress, string Type, string DeviceType, string Vendor, string Description, string ModelId, string PowerSource);
}
