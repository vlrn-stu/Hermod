                    </div>
                    <button class="btn btn-primary w-100" @onclick="SendLogMessage" disabled="@(!MqttService.IsConnected)">
                        Send Log Message
                    </button>
                </div>
            </div>
        }
        else if (_activeTab == "requests")
        {
            <!-- Request/Response Simulator -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent border-0">
                    <h5 class="mb-0 fw-semibold">Request Actions</h5>
                    <small class="text-muted">Send zigbee/bridge/request/* messages</small>
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Permit Join Control</label>
                            <div class="btn-group w-100" role="group">
                                <button class="btn btn-outline-success" @onclick="() => SendPermitJoin(true)" disabled="@(!MqttService.IsConnected)">
                                    Enable (254s)
                                </button>
                                <button class="btn btn-outline-danger" @onclick="() => SendPermitJoin(false)" disabled="@(!MqttService.IsConnected)">
                                    Disable
                                </button>
