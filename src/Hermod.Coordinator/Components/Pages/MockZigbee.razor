                            </button>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <h6 class="fw-semibold mb-3">Device Actions</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Target Device</label>
                            <select class="form-select" @bind="_requestDeviceIndex">
                                @for (int i = 0; i < _mockDevices.Count; i++)
                                {
                                    <option value="@i">@_mockDevices[i].FriendlyName</option>
                                }
