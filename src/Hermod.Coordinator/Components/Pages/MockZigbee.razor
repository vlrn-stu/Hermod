                <div class="card-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Response Type</label>
                            <select class="form-select" @bind="_responseType">
                                <option value="permit_join">permit_join</option>
                                <option value="health_check">health_check</option>
                                <option value="device/configure">device/configure</option>
                                <option value="device/rename">device/rename</option>
                                <option value="device/remove">device/remove</option>
                                <option value="networkmap">networkmap</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <select class="form-select" @bind="_responseStatus">
                                <option value="ok">OK</option>
                                <option value="error">Error</option>
                            </select>
                        </div>
                    </div>
                    <button class="btn btn-primary w-100" @onclick="SendMockResponse" disabled="@(!MqttService.IsConnected)">
