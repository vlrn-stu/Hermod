                        </button>
                        <button class="btn btn-outline-primary" @onclick="SendDeviceInterview" disabled="@(!MqttService.IsConnected)">
                            Interview
                        </button>
                        <button class="btn btn-outline-warning text-dark" @onclick="SendDeviceRename" disabled="@(!MqttService.IsConnected || string.IsNullOrEmpty(_newDeviceName))">
                            Rename
                        </button>
                        <button class="btn btn-outline-danger" @onclick="SendDeviceRemove" disabled="@(!MqttService.IsConnected)">
                            Remove
