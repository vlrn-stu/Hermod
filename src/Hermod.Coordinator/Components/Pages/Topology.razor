    private Task FitGraph() => _initialized ? JS.InvokeVoidAsync("fitTopology").AsTask() : Task.CompletedTask;
    private Task RunLayout() => _initialized ? JS.InvokeVoidAsync("layoutTopology").AsTask() : Task.CompletedTask;

    private object BuildGraphData()
    {
        var nodes = new List<object>();
        var edges = new List<object>();

        nodes.Add(new { data = new { id = "hermod-hub", label = "HERMOD", type = "hub" } });

        var sortedDevices = _devices
            .OrderBy(d => d.Protocol.ToString())
            .ThenBy(d => d.Name ?? d.Id);

        foreach (var device in sortedDevices)
        {
            var protoName = device.Protocol.ToString().ToLower();
            var protoDisplay = device.Protocol.ToDisplayName();
            var isActive = device.Status == DeviceStatus.Online ||
                          (device.LastSeen != default && DateTime.UtcNow - device.LastSeen < TimeSpan.FromMinutes(5));

            var deviceId = $"device-{device.Id}";
            var fullName = device.Name ?? device.Id;
            // Emit a searchable blob: name + id + manufacturer + model + protocol + topic base.
            var searchBlob = string.Join(" ",
                fullName,
                device.Id,
                device.Manufacturer ?? string.Empty,
                device.Model ?? string.Empty,
                protoName,
                protoDisplay,
                device.TopicBase ?? string.Empty).ToLowerInvariant();

            nodes.Add(new
            {
                data = new
                {
                    id = deviceId,
                    deviceId = device.Id,
                    label = fullName,
                    fullName,
                    type = "device",
                    protocol = protoName,
                    protocolDisplay = protoDisplay,
                    manufacturer = device.Manufacturer ?? string.Empty,
                    model = device.Model ?? string.Empty,
                    topicBase = device.TopicBase ?? string.Empty,
                    lastSeen = device.LastSeen.ToString("u"),
                    status = isActive ? "online" : "offline",
                    search = searchBlob
                }
            });

            edges.Add(new
            {
                data = new
                {
                    id = $"link-{device.Id}",
                    source = "hermod-hub",
                    target = deviceId,
                    type = "device-link",
                    protocol = protoName
                }
            });
        }

        var edgeSet = new HashSet<string>();
        foreach (var rule in _rules.Where(r => r.Enabled))
        {
            var sourceTopic = rule.Trigger.TopicPattern;
            var targetTopic = rule.Actions.FirstOrDefault()?.Topic ?? "";
            var sourceDevices = FindDevicesByTopic(sourceTopic);
            var targetDevices = FindDevicesByTopic(targetTopic);

            foreach (var sourceDevice in sourceDevices)
            {
                foreach (var targetDevice in targetDevices)
                {
                    if (sourceDevice.Id == targetDevice.Id) continue;

                    var edgeKey = $"{sourceDevice.Id}->{targetDevice.Id}:{rule.Id}";
                    if (!edgeSet.Add(edgeKey)) continue;

                    edges.Add(new
                    {
                        data = new
                        {
                            id = $"rule-{rule.Id}-{sourceDevice.Id}-{targetDevice.Id}",
                            source = $"device-{sourceDevice.Id}",
                            target = $"device-{targetDevice.Id}",
                            label = rule.Name,
                            fullLabel = rule.Name,
                            type = "rule",
                            ruleId = rule.Id,
                            sourceTopic,
                            targetTopic,
                            execCount = rule.ExecutionCount
                        }
                    });
                }
            }
        }

        return new { nodes, edges };
    }

    /// <summary>
    /// Find devices whose <see cref="Device.TopicBase"/> is matched by the
    /// given MQTT topic pattern (supports <c>+</c> and <c>#</c> wildcards via
    /// <see cref="MqttTopicMatcher"/>).
    /// </summary>
    private List<Device> FindDevicesByTopic(string topicPattern)
    {
        if (string.IsNullOrEmpty(topicPattern)) return new List<Device>();

        return _devices
            .Where(d => !string.IsNullOrEmpty(d.TopicBase) &&
                        MqttTopicMatcher.IsMatch(topicPattern, d.TopicBase))
            .ToList();
    }

    private List<Rule> GetVisibleRules()
    {
        var enabled = _rules.Where(r => r.Enabled);
        if (string.IsNullOrWhiteSpace(_search)) return enabled.ToList();

        var q = _search.Trim().ToLowerInvariant();
        return enabled.Where(r =>
            (r.Name?.ToLowerInvariant().Contains(q) ?? false) ||
            (r.Trigger.TopicPattern?.ToLowerInvariant().Contains(q) ?? false) ||
            (r.Actions.FirstOrDefault()?.Topic?.ToLowerInvariant().Contains(q) ?? false)).ToList();
    }

    private IEnumerable<Protocol> GetActiveProtocols()
    {
        return _devices
            .Select(d => d.Protocol)
            .Distinct()
            .OrderBy(p => p.ToString());
    }

    private static string GetProtocolColor(Protocol protocol) => protocol switch
    {
        Protocol.Zigbee => "#22C55E",
        Protocol.Bluetooth => "#0EA5E9",
        Protocol.Lora => "#F97316",
        Protocol.Wifi => "#A855F7",
        Protocol.Unknown => "#64748B",
        _ => "#64748B"
    };

    private static string FormatProtocolName(Protocol protocol) => protocol.ToDisplayName();

    private static string FormatCount(long n)
    {
        if (n >= 1_000_000) return $"{n / 1_000_000.0:0.#}M";
        if (n >= 1_000) return $"{n / 1_000.0:0.#}k";
        return n.ToString();
    }

    private static string Truncate(string? s, int max)
    {
        if (string.IsNullOrEmpty(s)) return string.Empty;
        return s.Length <= max ? s : s[..(max - 1)] + "…";
    }

    public async ValueTask DisposeAsync()
    {
        _pageCts.Cancel();
        _pageCts.Dispose();
        _selfRef?.Dispose();
        _selfRef = null;

        // `@rendermode InteractiveServer` disposes the prerendered component
        // instance as soon as the circuit boots its interactive copy.
        // The prerendered instance never runs OnAfterRenderAsync, so
        // _initialized is false and JS interop is unavailable during its
        // disposal — calling destroyTopology there throws
        // InvalidOperationException and spams the logs. Only invoke when
        // we actually mounted a graph this lifetime.
        if (!_initialized) return;

        try { await JS.InvokeVoidAsync("destroyTopology"); }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException) { /* static-render path; graph never mounted */ }
        catch (Exception ex) { Logger.LogDebug(ex, "Topology JS teardown threw on disposal"); }
    }
}
