        ActionType.Chain => string.IsNullOrEmpty(a.ChainToRule) ? "chain ?" : $"chain → {a.ChainToRule}{(string.IsNullOrEmpty(a.Delay) ? "" : $" after {a.Delay}")}",
        ActionType.SetState => "set state",
        ActionType.Conditional => "if/then/else",
        ActionType.Delay => string.IsNullOrEmpty(a.Delay) ? "delay ?" : $"delay {a.Delay}",
        ActionType.Parallel => "parallel",
        ActionType.Log => "log",
        ActionType.Webhook => string.IsNullOrEmpty(a.WebhookUrl) ? $"{a.WebhookMethod} ?" : $"{a.WebhookMethod} {a.WebhookUrl}",
        ActionType.Stop => "stop",
        ActionType.CancelDelay => "cancel delay",
        _ => a.Type.ToString().ToLowerInvariant()
    };

