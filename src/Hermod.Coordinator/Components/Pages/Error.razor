@page "/Error"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using System.Diagnostics
@layout MainLayout

<PageTitle>Error - Hermod</PageTitle>

<div class="error-container">
    <div class="error-content">
        <div class="error-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
            </svg>
        </div>
        <h1>Something went wrong</h1>
        <p class="text-muted">An error occurred while processing your request.</p>

        @if (ShowRequestId)
        {
            <div class="request-id">
                <small class="text-muted">Request ID:</small>
                <code>@RequestId</code>
            </div>
        }

        <div class="mt-4 d-flex gap-2 justify-content-center">
            <a href="/" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                Back to Dashboard
            </a>
            <button class="btn btn-outline-secondary" onclick="location.reload()">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/>
                    <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/>
                </svg>
                Reload
            </button>
        </div>
    </div>
</div>

<style>
    .error-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        text-align: center;
    }

    .error-content {
        max-width: 500px;
    }

    .error-icon {
        color: var(--hermod-danger);
        margin-bottom: 1.5rem;
    }

    .error-content h1 {
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .request-id {
        background: var(--hermod-bg-secondary);
        border: 1px solid var(--hermod-border);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-top: 1.5rem;
    }

    .request-id code {
        display: block;
        margin-top: 0.25rem;
        font-size: 0.875rem;
    }
</style>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
