@page "/messages"
@using Hermod.Core.Interfaces
@using Hermod.Core.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IMqttService MqttService
@inject IJSRuntime JS
@inject ILogger<Messages> Logger
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Messages - Hermod</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1 fw-bold">MQTT Messages</h1>
        <p class="text-muted mb-0">Real-time message log from all protocols</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <span class="badge @(MqttService.IsConnected ? "bg-success" : "bg-danger") fs-6 px-3 py-2">
            @(MqttService.IsConnected ? "Connected" : "Disconnected")
        </span>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100 hermod-gradient-4">
            <div class="card-body text-white">
                <h6 class="text-white-50 mb-2">Total Messages</h6>
                <h2 class="mb-0 fw-bold">@_messages.Count</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100 protocol-zigbee">
            <div class="card-body text-white">
                <h6 class="text-white-50 mb-2">ZigBee</h6>
                <h2 class="mb-0 fw-bold">@_messages.Count(m => m.Topic.StartsWith("zigbee/"))</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100 protocol-bluetooth">
            <div class="card-body text-white">
                <h6 class="text-white-50 mb-2">Bluetooth</h6>
                <h2 class="mb-0 fw-bold">@_messages.Count(m => m.Topic.StartsWith("bluetooth/"))</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100 protocol-lora">
            <div class="card-body text-white">
                <h6 class="text-white-50 mb-2">LoRa / WiFi</h6>
                <h2 class="mb-0 fw-bold">@(_messages.Count(m => m.Topic.StartsWith("lora/") || m.Topic.StartsWith("wifi/")))</h2>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small text-muted">Filter Topic</label>
                <input type="text" class="form-control" @bind="_topicFilter" @bind:event="oninput" placeholder="e.g., zigbee/#" />
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted">Protocol</label>
                <select class="form-select" @bind="_protocolFilter">
                    <option value="">All Protocols</option>
                    <option value="zigbee">ZigBee</option>
                    <option value="bluetooth">Bluetooth</option>
                    <option value="lora">LoRa</option>
                    <option value="wifi">WiFi</option>
                </select>
            </div>
            <div class="col-md-3">
                <div class="d-flex align-items-center gap-3 h-100">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="autoScroll" @bind="_autoScroll" />
                        <label class="form-check-label" for="autoScroll">Auto-scroll</label>
                    </div>
                </div>
            </div>
            <div class="col-md-2 text-end">
                <div class="btn-group">
                    <button class="btn @(_isPaused ? "btn-success" : "btn-warning")" @onclick="TogglePause">
                        @if (_isPaused)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16">
                                <path d="m11.596 8.697-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393z"/>
                            </svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16">
                                <path d="M5.5 3.5A1.5 1.5 0 0 1 7 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5zm5 0A1.5 1.5 0 0 1 12 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5z"/>
                            </svg>
                        }
                        @(_isPaused ? "Resume" : "Pause")
                    </button>
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" disabled="@(!_messages.Any())">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16">
                                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                                <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                            </svg>
                            Export
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><button class="dropdown-item" @onclick="ExportAsJson">Export as JSON</button></li>
                            <li><button class="dropdown-item" @onclick="ExportAsCsv">Export as CSV</button></li>
                        </ul>
                    </div>
                    <button class="btn btn-outline-secondary" @onclick="ClearMessages">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                            <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1z"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Messages List -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center py-3">
        <span class="fw-semibold">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2 text-primary" viewBox="0 0 16 16">
                <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/>
                <path d="M3 5.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zM3 8a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9A.5.5 0 0 1 3 8zm0 2.5a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5z"/>
            </svg>
            Showing @FilteredMessages.Count() of @_messages.Count messages
        </span>
        <small class="text-muted">Max buffer: @_maxMessages</small>
    </div>
    <div class="card-body p-0">
        <div class="message-log" style="height: 500px; overflow-y: auto;" @ref="_logContainer">
            @if (FilteredMessages.Any())
            {
                @foreach (var msg in FilteredMessages)
                {
                    <div class="message-item @GetRowClass(msg)" @onclick="() => ShowPayload(msg)">
                        <div class="message-time">@msg.ReceivedAt.ToLocalTime().ToString("HH:mm:ss.fff")</div>
                        <div class="message-protocol">
                            <span class="badge @GetProtocolBadgeClass(msg.Topic)">@GetProtocolName(msg.Topic)</span>
                        </div>
                        <div class="message-topic">
                            <code>@msg.Topic</code>
                        </div>
                        <div class="message-payload">
                            @if (IsJson(msg.Payload))
                            {
                                <span class="json-preview">@TruncatePayload(msg.Payload)</span>
                            }
                            else
                            {
                                <span>@TruncatePayload(msg.Payload)</span>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="mb-3 opacity-50" viewBox="0 0 16 16">
                        <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/>
                    </svg>
                    <p class="mb-1">No messages yet</p>
                    <small>Waiting for MQTT messages...</small>
                </div>
            }
        </div>
    </div>
</div>

<!-- Message Detail Modal -->
@if (_selectedMessage != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: var(--hermod-overlay); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 hermod-gradient-1">
                    <h5 class="modal-title text-white">Message Details</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ClosePayload"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted small">Topic</label>
                        <code class="d-block p-2 bg-light rounded">@_selectedMessage.Topic</code>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small">Received At</label>
                        <div class="p-2 bg-light rounded">@_selectedMessage.ReceivedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss.fff")</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small d-flex justify-content-between">
                            <span>Payload</span>
                            <button class="btn btn-sm btn-link p-0" @onclick="CopyPayload">Copy</button>
                        </label>
                        <pre class="p-3 bg-light rounded small mb-0" style="max-height: 400px; overflow: auto;">@FormatJson(_selectedMessage.Payload)</pre>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" @onclick="ClosePayload">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .message-log {
        font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', monospace;
        font-size: 0.85rem;
    }

    .message-item {
        display: grid;
        grid-template-columns: 100px 80px 1fr 1fr;
        gap: 1rem;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--hermod-border);
        cursor: pointer;
        transition: background 0.15s ease;
    }

    .message-item:hover {
        background: var(--hermod-bg-secondary);
    }

    .message-item.highlight-set {
        background: rgba(var(--hermod-primary-rgb), 0.15);
    }

    .message-item.highlight-get {
        background: rgba(59, 130, 246, 0.15);
    }

    .message-time {
        color: var(--hermod-text-muted);
        font-size: 0.75rem;
    }

    .message-protocol .badge {
        font-size: 0.65rem;
        font-weight: 600;
    }

    .message-topic code {
        font-size: 0.75rem;
        color: var(--hermod-text);
        background: none;
    }

    .message-payload {
        color: var(--hermod-text-muted);
        font-size: 0.75rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .json-preview {
        color: var(--hermod-success);
    }
</style>

@code {
    private readonly List<MqttMessage> _messages = new();
    private const int _maxMessages = 500;
    private string _topicFilter = "";
    private string _protocolFilter = "";
    private bool _autoScroll = true;
    private bool _isPaused = false;
    private MqttMessage? _selectedMessage;
    private ElementReference _logContainer;

    private IEnumerable<MqttMessage> FilteredMessages
    {
        get
        {
            MqttMessage[] snapshot;
            lock (_messages)
            {
                snapshot = _messages.ToArray();
            }

            return snapshot
                .Where(m => string.IsNullOrEmpty(_topicFilter) || m.Topic.Contains(_topicFilter, StringComparison.OrdinalIgnoreCase))
                .Where(m => string.IsNullOrEmpty(_protocolFilter) || m.Topic.StartsWith(_protocolFilter, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(m => m.ReceivedAt)
                .Take(100);
        }
    }

    protected override void OnInitialized()
    {
        var history = MqttService.GetMessageHistory();
        lock (_messages)
        {
            _messages.AddRange(history);
        }

        MqttService.MessageReceived += HandleMessage;
    }

    private void HandleMessage(object? sender, MqttMessage message)
    {
        if (_isPaused) return;

        lock (_messages)
        {
            _messages.Add(message);
            if (_messages.Count > _maxMessages)
            {
                _messages.RemoveAt(0);
            }
        }

        InvokeAsync(StateHasChanged);
    }

    private void ClearMessages()
    {
        lock (_messages)
        {
            _messages.Clear();
        }
        _selectedMessage = null;
    }

    private void TogglePause() => _isPaused = !_isPaused;
    private void ShowPayload(MqttMessage msg) => _selectedMessage = msg;
    private void ClosePayload() => _selectedMessage = null;
    private async Task CopyPayload()
    {
        if (_selectedMessage != null)
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _selectedMessage.Payload);
        }
    }

    private async Task ExportAsJson()
    {
        var exportData = _messages.Select(m => new
        {
            topic = m.Topic,
            payload = m.Payload,
            receivedAt = m.ReceivedAt.ToString("o"),
            protocol = GetProtocolName(m.Topic)
        });

        var json = System.Text.Json.JsonSerializer.Serialize(exportData, new System.Text.Json.JsonSerializerOptions
        {
            WriteIndented = true
        });

        var fileName = $"hermod-messages-{DateTime.Now:yyyyMMdd-HHmmss}.json";
        await DownloadFile(fileName, json, "application/json");
    }

    private async Task ExportAsCsv()
    {
        MqttMessage[] snapshot;
        lock (_messages)
        {
            snapshot = _messages.ToArray();
        }

        var csv = new System.Text.StringBuilder();
        csv.AppendLine("Timestamp,Protocol,Topic,Payload");

        foreach (var msg in snapshot.OrderByDescending(m => m.ReceivedAt))
        {
            csv.AppendLine(string.Join(',', new[]
            {
                CsvEscape(msg.ReceivedAt.ToString("yyyy-MM-dd HH:mm:ss.fff")),
                CsvEscape(GetProtocolName(msg.Topic)),
                CsvEscape(msg.Topic),
                CsvEscape(msg.Payload)
            }));
        }

        var fileName = $"hermod-messages-{DateTime.Now:yyyyMMdd-HHmmss}.csv";
        await DownloadFile(fileName, csv.ToString(), "text/csv");
    }

    private static string CsvEscape(string value)
    {
        // RFC 4180: double quotes, then wrap; newlines become literal characters
        // inside the quoted field which is valid CSV.
        var escaped = (value ?? string.Empty).Replace("\"", "\"\"");
        return $"\"{escaped}\"";
    }

    private async Task DownloadFile(string fileName, string content, string mimeType)
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(content);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval", $@"
            var link = document.createElement('a');
            link.href = 'data:{mimeType};base64,{base64}';
            link.download = '{fileName}';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        ");
    }

    private static string GetProtocolName(string topic)
    {
        if (topic.StartsWith("zigbee/")) return "ZigBee";
        if (topic.StartsWith("bluetooth/")) return "BLE";
        if (topic.StartsWith("lora/")) return "LoRa";
        if (topic.StartsWith("wifi/")) return "WiFi";
        if (topic.StartsWith("hermod/")) return "System";
        if (topic.StartsWith("alerts/")) return "Alert";
        return "Other";
    }

    private static string GetProtocolBadgeClass(string topic)
    {
        if (topic.StartsWith("zigbee/")) return "bg-success";
        if (topic.StartsWith("bluetooth/")) return "bg-info";
        if (topic.StartsWith("lora/")) return "bg-warning text-dark";
        if (topic.StartsWith("wifi/")) return "bg-primary";
        if (topic.StartsWith("hermod/")) return "bg-dark";
        if (topic.StartsWith("alerts/")) return "bg-danger";
        return "bg-secondary";
    }

    private static string GetRowClass(MqttMessage msg)
    {
        if (msg.Topic.Contains("/set")) return "highlight-set";
        if (msg.Topic.Contains("/get")) return "highlight-get";
        return "";
    }

    private static bool IsJson(string payload)
    {
        if (string.IsNullOrEmpty(payload)) return false;
        var trimmed = payload.Trim();
        return (trimmed.StartsWith("{") && trimmed.EndsWith("}")) ||
               (trimmed.StartsWith("[") && trimmed.EndsWith("]"));
    }

    private static string TruncatePayload(string payload)
    {
        if (string.IsNullOrEmpty(payload)) return "(empty)";
        if (payload.Length <= 80) return payload;
        return payload[..77] + "...";
    }

    private static string FormatJson(string payload)
    {
        try
        {
            if (IsJson(payload))
            {
                var obj = System.Text.Json.JsonSerializer.Deserialize<object>(payload);
                return System.Text.Json.JsonSerializer.Serialize(obj, new System.Text.Json.JsonSerializerOptions
                {
                    WriteIndented = true
                });
            }
        }
        catch { }
        return payload;
    }

    public void Dispose()
    {
        MqttService.MessageReceived -= HandleMessage;
    }
}
