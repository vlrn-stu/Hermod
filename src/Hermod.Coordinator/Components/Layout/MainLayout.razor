@inherits LayoutComponentBase

<style>
    .page {
        position: relative;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }
    main {
        flex: 1;
        background-color: var(--hermod-bg);
        color: var(--hermod-text);
        transition: background-color 0.3s, color 0.3s;
    }
    .sidebar {
        background: var(--hermod-sidebar-bg);
    }
    .content {
        padding-top: 1.5rem;
    }
    @@media (max-width: 640.98px) {
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
        }
        main {
            padding-top: 3.5rem;
        }
    }
    @@media (min-width: 641px) {
        .page {
            flex-direction: row;
        }
        .sidebar {
            width: 250px;
            height: 100vh;
            position: sticky;
            top: 0;
            flex-shrink: 0;
        }
        .content {
            padding-left: 2rem !important;
            padding-right: 1.5rem !important;
        }
    }
</style>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet style="display: none;">
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

