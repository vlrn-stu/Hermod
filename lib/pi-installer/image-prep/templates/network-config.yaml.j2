# Generated by hermod-pi image-prep v{{ tool_version }}
# netplan v2 — consumed by cloud-init NoCloud as `network-config`.
version: 2
renderer: networkd
ethernets:
  eth0:
    dhcp4: true
    optional: true
{% if wifi %}
wifis:
  wlan0:
    dhcp4: true
    optional: true
    regulatory-domain: {{ wifi.country }}
    access-points:
      "{{ wifi.ssid }}":
        password: "{{ wifi.passphrase }}"
{% endif %}
