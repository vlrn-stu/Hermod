#cloud-config
# Generated by hermod-pi image-prep v{{ tool_version }}
# Target hostname: {{ hostname }}
# DO NOT EDIT THIS FILE ON THE SD CARD — regenerate via hermod-pi.

hostname: {{ hostname }}
manage_etc_hosts: true
preserve_hostname: false

locale: {{ locale }}
timezone: {{ timezone }}

# Kill password SSH globally + disable root login.
ssh_pwauth: false
disable_root: true

users:
  - name: {{ username }}
    gecos: hermod-pi provisioned user
    shell: /bin/bash
    groups: [adm, sudo, dialout, audio, video, plugdev, netdev, lxd]
    lock_passwd: true
{% if sudo_nopasswd %}
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
{% else %}
    sudo: ["ALL=(ALL) ALL"]
{% endif %}
    ssh_authorized_keys:
      - {{ ssh_pubkey }}

# Belt-and-suspenders: the preinstalled Pi image already has these,
# but we don't trust that upstream always will.
package_update: true
package_upgrade: false
packages:
  - snapd
  - openssh-server
  - ca-certificates
  - python3
  - curl

write_files:
  - path: /etc/hermod-pi/provisioned.json
    permissions: "0644"
    owner: root:root
    content: |
      {
        "hostname": "{{ hostname }}",
        "generated_at": "{{ generated_at }}",
        "tool_version": "{{ tool_version }}",
        "ubuntu_version": "{{ ubuntu_version }}"
      }
  - path: /etc/ssh/sshd_config.d/10-hermod-pi.conf
    permissions: "0644"
    owner: root:root
    content: |
      # hermod-pi enforced: key auth only, no root.
      PasswordAuthentication no
      PermitRootLogin no
      KbdInteractiveAuthentication no
      ChallengeResponseAuthentication no

# Timezone via timedatectl (cloud-init's `timezone:` handles it too, but
# explicit re-apply makes logs deterministic) + regenerate SSH host keys
# so every flashed card gets unique identities.
runcmd:
  - [ timedatectl, set-timezone, "{{ timezone }}" ]
  - [ sh, -c, "rm -f /etc/ssh/ssh_host_*" ]
  - [ dpkg-reconfigure, openssh-server ]
  - [ systemctl, restart, ssh ]
{% for cmd in extra_runcmd %}
  - {{ cmd }}
{% endfor %}

final_message: "hermod-pi first-boot complete: {{ hostname }} up after $UPTIME seconds"
