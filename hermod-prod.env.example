# hermod-prod.env — operator-supplied prod secrets.
#
# Copy to hermod-prod.env (gitignored) and fill in values before running:
#   hermod.sh install prod-kind   # or  redeploy prod-kind
#
# hermod.sh sources this file (when present) and runs
# scripts/lib/ensure-secrets.sh in `from-env` mode — each variable below
# becomes the value of the matching k8s Secret key in hermod-prod.
# Anything you leave blank logs a warning and falls back to the placeholder
# defaults; for prod, fill EVERY field.
#
# Override the path with HERMOD_PROD_ENV=/elsewhere/hermod-prod.env

# ── Pi SSH coordinates (consumed by resolve_target in hermod.sh) ───────
# Where to reach the Pi over SSH for every prod-pi* target. Default user
# is `hermod` (created by the hermod-pi cloud-init image); override only
# if you self-flashed and provisioned a different account.
# HERMOD_PI_SSH_USER=hermod
HERMOD_PI_SSH_HOST=10.0.0.1
HERMOD_PI_SSH_KEY=$HOME/.hermod-pi/keys/your-pi-hostname.key
# HERMOD_PI_KNOWN_HOSTS=$HOME/.hermod-pi/known_hosts

# ── MQTT broker credential (shared by coord + every translator) ─────────
HERMOD_MQTT_USERNAME=hermod-service
HERMOD_MQTT_PASSWORD=

# ── NanoMQ HTTP admin (broker management API on :8081) ─────────────────
HERMOD_NANOMQ_ADMIN_USERNAME=admin
HERMOD_NANOMQ_ADMIN_PASSWORD=

# ── Postgres (hermod app DB user) ──────────────────────────────────────
HERMOD_PG_PASSWORD=

# ── Vault42 crypto material (256-bit base64 each — openssl rand -base64 32) ──
HERMOD_VAULT42_MASTER_KEY=
HERMOD_VAULT42_HMAC_SECRET=
HERMOD_VAULT42_SIGNING_KEY=

# ── Vault42 DB role passwords (vault_mig is also postgres master) ──────
HERMOD_VAULT42_DB_MIG_PASSWORD=
HERMOD_VAULT42_DB_APP_PASSWORD=

# ── Vault42 first-boot seed accounts ───────────────────────────────────
# Imported once on initial vault42 boot then deleted from the Secret.
# Rotate via the dashboard immediately after first login. Three
# accounts are seeded by default:
#   viewer@hermod.local    — read-only
#   user@hermod.local      — basic device interaction
#   operator@hermod.local  — operator + admin, full UI surface
# Set HERMOD_SEED_VIEWER=0 or HERMOD_SEED_USER=0 below to skip seeding
# those accounts; operator is always seeded since the system needs at
# least one full-control identity to bootstrap from.
HERMOD_VAULT42_VIEWER_PASSWORD=
HERMOD_VAULT42_USER_PASSWORD=
HERMOD_VAULT42_OPERATOR_PASSWORD=
HERMOD_SEED_VIEWER=1
HERMOD_SEED_USER=1
